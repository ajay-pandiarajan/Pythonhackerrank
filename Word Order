from collections import OrderedDict

# Read the number of words
n = int(input())

# Initialize the OrderedDict to track counts and order
word_counts = OrderedDict()

for _ in range(n):
    word = input().strip()
    # Increment the count for the word
    if word in word_counts:
        word_counts[word] += 1
    else:
        word_counts[word] = 1

# Output the number of distinct words
print(len(word_counts))

# Output the occurrences in order of first appearance
# Map the integer values to strings to use join()
print(" ".join(map(str, word_counts.values())))
