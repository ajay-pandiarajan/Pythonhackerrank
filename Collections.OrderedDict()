from collections import OrderedDict

# Initialize the ordered dictionary
inventory = OrderedDict()

# Read the number of items
n = int(input())

for _ in range(n):
    # Split from the right once to separate the name and price
    data = input().rsplit(' ', 1)
    item_name = data[0]
    price = int(data[1])
    
    # If the item exists, add to the price; otherwise, initialize it
    if item_name in inventory:
        inventory[item_name] += price
    else:
        inventory[item_name] = price

# Print the results in order of first occurrence
for item, net_price in inventory.items():
    print(f"{item} {net_price}")
