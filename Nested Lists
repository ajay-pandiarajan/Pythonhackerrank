n = int(input())
students = [[input(), float(input())] for _ in range(n)]

# 1. Get all unique grades and sort them to find the second lowest
grades = sorted(list(set([s[1] for s in students])))
second_lowest_grade = grades[1]

# 2. Filter students with that grade and sort their names alphabetically
result_names = sorted([s[0] for s in students if s[1] == second_lowest_grade])

# 3. Print each name on a new line
for name in result_names:
    print(name)
